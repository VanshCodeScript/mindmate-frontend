# Frontend Environment Variables
# MindBridge Phone Authentication with Twilio

# ============================================================================
# API CONFIGURATION
# ============================================================================
# VITE_API_BASE_URL is NOT set so that the app auto-detects the hostname
# (supports LAN access from other devices on the same WiFi)
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
VITE_APP_NAME=MindBridge
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# ============================================================================
# AUTHENTICATION SETTINGS
# ============================================================================
VITE_AUTH_TOKEN_STORAGE=localStorage
VITE_AUTO_LOGOUT_TIMEOUT=3600000
VITE_REMEMBER_ME_DURATION=7d

# ============================================================================
# FEATURE FLAGS
# ============================================================================
VITE_FEATURE_VOICE_ENABLED=true
VITE_FEATURE_VOICE_SPEECH_RECOGNITION=true
VITE_FEATURE_VOICE_SYNTHESIS=true
VITE_FEATURE_GEOFENCE_ENABLED=true
VITE_FEATURE_CHARTS_ENABLED=true
VITE_FEATURE_REAL_TIME_ALERTS=true
VITE_FEATURE_ELDERLY_CHATBOT=true
VITE_FEATURE_CAREGIVER_DASHBOARD=true

# ============================================================================
# UI/UX CONFIGURATION
# ============================================================================
VITE_THEME_DARK_MODE=false
VITE_THEME_PRIMARY_COLOR=#3B82F6
VITE_THEME_ACCENT_COLOR=#F59E0B

# Accessibility
VITE_A11Y_ENABLED=true
VITE_A11Y_FONT_SIZE_BOOST=false
VITE_A11Y_HIGH_CONTRAST=false

# ============================================================================
# VOICE SETTINGS
# ============================================================================
VITE_VOICE_RECOGNITION_LANGUAGE=en-US
VITE_VOICE_RECOGNITION_CONTINUOUS=false
VITE_VOICE_RECOGNITION_INTERIM_RESULTS=true
VITE_VOICE_SYNTHESIS_LANGUAGE=en-US
VITE_VOICE_SYNTHESIS_RATE=1.0
VITE_VOICE_SYNTHESIS_PITCH=1.0

# ============================================================================
# GEOLOCATION & MAPPING
# ============================================================================
VITE_GEOLOCATION_ENABLED=true
VITE_GEOLOCATION_TIMEOUT=10000
VITE_GEOLOCATION_MAX_AGE=3600000
VITE_GEOLOCATION_HIGH_ACCURACY=false
VITE_MAP_DEFAULT_ZOOM=13
VITE_MAP_DEFAULT_CENTER_LAT=40.7128
VITE_MAP_DEFAULT_CENTER_LNG=-74.0060

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
VITE_SHOW_DEBUG_INFO=false
VITE_ENABLE_REDUX_DEVTOOLS=true
VITE_ENABLE_REACT_PROFILER=false
